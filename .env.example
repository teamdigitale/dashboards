# Discourse API key (https://forum.italia.it admin panel)
FORUM_API_KEY=

# GitHub fine-grained personal access token
# (https://github.com/settings/personal-access-tokens/new):
#   - Resource owner: italia
#   - Repository access: Public repositories (read-only)
#   - Permissions: leave all defaults
# The github engine reads public data only; the token just raises the REST
# rate limit from 60/h to 5000/h.
GITHUB_TOKEN=

# Optional
LOG_LEVEL=INFO      # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=text     # text (default) | json
